generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                             String                  @id @default(cuid())
  name                           String?
  email                          String                  @unique
  emailVerified                  DateTime?
  image                          String?
  password                       String
  role                           Role                    @default(STUDENT)
  studentCode                    String?                 @unique
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
  requirePasswordChange          Boolean                 @default(true)
  accounts                       Account[]
  activitySubmissions            ActivitySubmission[]
  adminLogs                      AdminLog[]
  advisorMeetingsAsAdvisor       AdvisorMeeting[]        @relation("AdvisorMeetings")
  advisorMeetingsAsStudent       AdvisorMeeting[]        @relation("StudentMeetings")
  advisorRecommendationsMade     AdvisorRecommendation[] @relation("AdvisorRecommendations")
  advisorRecommendationsReceived AdvisorRecommendation[] @relation("StudentRecommendations")
  teacherAssignment              Assignment[]
  submissions                    AssignmentSubmission[]
  attendances                    Attendance[]
  Authenticator                  Authenticator[]
  enrollments                    Enrollment[]
  examResults                    ExamResult[]
  sessions                       Session[]
  studentExamPapers              StudentExamPaper[]
  insights                       StudentInsight[]
  receivedNotifications          SystemNotification[]    @relation("ReceivedNotifications")
  sentNotifications              SystemNotification[]    @relation("SentNotifications")
  teachings                      TeacherCourse[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String
  expires DateTime
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Course {
  id                 String              @id @default(cuid())
  name               String
  code               String              @unique
  description        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignments        Assignment[]
  attendances        Attendance[]
  attendanceSessions AttendanceSession[]
  students           Enrollment[]
  exams              Exam[]
  studentActivities  StudentActivity[]
  teachers           TeacherCourse[]
}

model Enrollment {
  id        String @id @default(cuid())
  studentId String
  courseId  String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model TeacherCourse {
  id        String @id @default(cuid())
  teacherId String
  courseId  String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, courseId])
}

model Attendance {
  id          String             @id @default(cuid())
  studentId   String
  courseId    String
  sessionId   String?
  cardId      String?
  faceMatched Boolean            @default(false)
  status      AttendanceStatus   @default(PRESENT)
  date        DateTime           @default(now())
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  session     AttendanceSession? @relation(fields: [sessionId], references: [id])
  student     User               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
  @@index([studentId])
  @@index([courseId])
}

model Exam {
  id        String             @id @default(cuid())
  title     String
  courseId  String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  course    Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  results   ExamResult[]
  config    OCRConfig?
  questions Question[]
  papers    StudentExamPaper[]
}

model Question {
  id             String           @id @default(cuid())
  examId         String
  text           String
  type           QuestionType     @default(MCQ)
  bubbleCount    Int              @default(4)
  x              Int?
  y              Int?
  width          Int?
  height         Int?
  correctAnswer  String
  marks          Int              @default(1)
  order          Int
  exam           Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  options        QuestionOption[]
  studentAnswers StudentAnswer[]

  @@index([examId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  label      String
  text       String
  sortOrder  Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, label])
}

model ExamResult {
  id              String   @id @default(cuid())
  examId          String
  studentId       String
  score           Float
  scannedPaperUrl String?
  rawOcrData      Json?
  createdAt       DateTime @default(now())
  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model Assignment {
  id            String                 @id @default(cuid())
  teacherId     String
  courseId      String
  title         String
  description   String?
  dueDate       DateTime
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  attachmentUrl String?
  course        Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher       User                   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions   AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  grade        Float?
  status       AssignmentStatus @default(PENDING)
  submittedAt  DateTime?
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model StudentActivity {
  id            String               @id @default(cuid())
  title         String
  description   String?
  type          ActivityType
  dueDate       DateTime?
  points        Int                  @default(0)
  courseId      String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  attachmentUrl String?
  attachments   ActivityAttachment[]
  contents      ActivityContent[]
  submissions   ActivitySubmission[]
  course        Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model ActivityContent {
  id         String          @id @default(cuid())
  activityId String
  type       ContentType
  title      String?
  body       String?
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  activity   StudentActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model ActivityAttachment {
  id         String          @id @default(cuid())
  activityId String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  createdAt  DateTime        @default(now())
  activity   StudentActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model ActivitySubmission {
  id          String           @id @default(cuid())
  activityId  String
  studentId   String
  textAnswer  String?
  fileUrl     String?
  score       Float?
  feedback    String?
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime?
  gradedAt    DateTime?
  activity    StudentActivity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([activityId, studentId])
}

model StudentInsight {
  id               String    @id @default(cuid())
  studentId        String
  riskLevel        RiskLevel
  confidence       Float?
  summary          String
  predictedOutcome String?
  recommendations  Json?
  reasons          Json?
  attendanceRate   Float?
  averageScore     Float?
  assignmentRate   Float?
  engagementScore  Float?
  inputSnapshot    Json?
  modelName        String?
  modelVersion     String?
  generatedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  student          User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([riskLevel])
  @@index([generatedAt])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  entityType  String?
  entityId    String?
  description String?
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AttendanceSession {
  id          String       @id @default(cuid())
  courseId    String
  active      Boolean      @default(true)
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  expiresAt   DateTime?
  attendances Attendance[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model StudentExamPaper {
  id             String          @id @default(cuid())
  examId         String
  studentId      String
  uniqueCode     String          @unique
  qrCodeUrl      String?
  status         PaperStatus     @default(GENERATED)
  scannedImage   String?
  processedImage String?
  ocrStatus      OCRStatus       @default(PENDING)
  totalScore     Float?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  answers        StudentAnswer[]
  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model StudentAnswer {
  id             String           @id @default(cuid())
  paperId        String
  questionId     String
  detectedAnswer String?
  isCorrect      Boolean?
  score          Float            @default(0)
  confidence     Float?
  needsReview    Boolean          @default(false)
  paper          StudentExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question       Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([paperId, questionId])
}

model OCRConfig {
  id        String  @id @default(cuid())
  examId    String  @unique
  threshold Int     @default(140)
  blur      Int     @default(3)
  invert    Boolean @default(true)
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model AdvisorRecommendation {
  id        String   @id @default(cuid())
  advisorId String
  studentId String
  text      String
  isWarning Boolean  @default(false)
  createdAt DateTime @default(now())
  advisor   User     @relation("AdvisorRecommendations", fields: [advisorId], references: [id], onDelete: Cascade)
  student   User     @relation("StudentRecommendations", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([studentId])
}

model SystemNotification {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedNotifications", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentNotifications", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([receiverId])
  @@index([senderId])
}

model AdvisorMeeting {
  id          String        @id @default(cuid())
  advisorId   String
  studentId   String
  meetingDate DateTime
  notes       String?
  status      MeetingStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())
  advisor     User          @relation("AdvisorMeetings", fields: [advisorId], references: [id], onDelete: Cascade)
  student     User          @relation("StudentMeetings", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([advisorId])
  @@index([studentId])
}

enum Role {
  STUDENT
  ADMIN
  TEACHER
  ADVISOR
  TA
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  REJECTED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  LATE
  GRADED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  TASK
  QUIZ
  PROJECT
  EXAM
  EVENT
}

enum ContentType {
  TEXT
  FILE
  LINK
  VIDEO
  IMAGE
  CODE
  QUESTION
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  LATE
  GRADED
}

enum PaperStatus {
  GENERATED
  PRINTED
  SUBMITTED
  SCANNED
  PROCESSED
  REVIEW_REQUIRED
  GRADED
}

enum OCRStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}
